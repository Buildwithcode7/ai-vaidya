# ============================================
# AI Vaidya - Environment Variables
# ============================================

# --- LLM API Keys (use at least one) ---
GROQ_API_KEY=your_groq_api_key_here
# Get free key at: https://console.groq.com

OPENAI_API_KEY=your_openai_api_key_here
# Optional fallback

HUGGINGFACE_API_KEY=your_hf_token_here
# Optional for HuggingFace Inference API

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=ayurveda_knowledge

# --- LLM Settings ---
LLM_PROVIDER=groq
# Options: groq | openai | huggingface
LLM_MODEL=llama3-70b-8192
# Groq models: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it

# --- RAG Settings ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RETRIEVAL=5

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Upload ---
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=./data/uploads
